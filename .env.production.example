# Production environment for the API service (set these in Railway → Variables).
# Generate the secrets with:  py scripts/gen_secrets.py
# Do NOT commit real values.

APP_ENV=production

# Secrets (generate — never reuse the dev placeholders)
APP_SECRET_KEY=__generate__
JWT_SECRET=__generate__
FERNET_KEY=__generate__            # encrypts OAuth tokens at rest; rotating it invalidates stored tokens

# Data — Railway provides these as reference variables when you add the plugins:
#   DATABASE_URL = ${{ Postgres.DATABASE_URL }}
#   REDIS_URL    = ${{ Redis.REDIS_URL }}
DATABASE_URL=postgresql://user:pass@host:5432/railway
REDIS_URL=redis://default:pass@host:6379

# Public URLs
API_BASE_URL=https://your-api.up.railway.app         # this API's public URL (used to build OAuth redirect URIs)
WEB_BASE_URL=https://your-app.vercel.app             # the frontend origin

# AI provider — use a real key in production, or keep "mock" to launch keyless
AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=sk-ant-__your_key__

# JWT lifetimes (optional overrides)
# JWT_ACCESS_TTL_MINUTES=30
# JWT_REFRESH_TTL_DAYS=30
