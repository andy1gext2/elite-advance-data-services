# Copy to .env and fill in. NEVER commit .env. All secrets are read from here in dev.

# ── App ─────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-prod
API_BASE_URL=http://127.0.0.1:8000
WEB_BASE_URL=http://127.0.0.1:3000

# ── Auth / JWT ──────────────────────────────────────
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=30

# ── Database ────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/elite
REDIS_URL=redis://localhost:6379/0

# ── Secrets encryption (encrypt OAuth tokens at rest) ─
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── AI providers (provider-agnostic layer) ──────────
# Set AI_DEFAULT_PROVIDER=mock to run content generation with no API key (dev/tests).
AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
# Optional fallbacks
OPENAI_API_KEY=

# ── Social / platform OAuth (fill as connectors are built) ─
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
